{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalChatBox",
  "version": "0.3.1",
  "identifier": "com.localchatbox.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalChatBox",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "resources": ["../runtime/win/llama-server*.exe", "../runtime/win/*.dll"],
    "shortDescription": "Private local AI chat",
    "longDescription": "Bundles a pinned llama.cpp CPU runtime, stores GGUF models in %LOCALAPPDATA%\\LocalChatBox\\models, and provides a ChatGPT-like local chat interface.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}
